# Development-only authoring tool. Vite removes DEV-only branches from production builds.
VITE_ENABLE_PLACEMENT_MODE=false

# Optional audio file URL. Audio is requested only after the visitor presses Enter.
VITE_AMBIENT_AUDIO_URL=

# OpenSeadragon zoom limits.
VITE_MAP_MIN_ZOOM=0.9
VITE_MAP_MAX_ZOOM=6

# Replace this with /map/world-map.dzi after installing your production 16K tiles.
VITE_MAP_TILE_SOURCE=/map/world-map.dzi
